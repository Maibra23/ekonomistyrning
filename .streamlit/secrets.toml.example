# Hugging Face Inference Providers token.
# Copy this file to secrets.toml (which is gitignored) and fill in your token.
# Never commit secrets.toml to version control.
HF_TOKEN = "hf_your_token_here"

# Model name on Hugging Face Inference Providers
LLM_MODEL = "Qwen/Qwen3-14B"

# Provider: "auto" lets HF route to the best available provider.
# Other options exist (together, fireworks, etc.) per HF Inference Providers docs.
LLM_PROVIDER = "auto"

# Optional: enable a second LLM pass when the first response fails structure check.
# Doubles cost for affected outputs. Default false.
LLM_HUMANIZER_FALLBACK = false
